# Environment
# Allowed values: scale, prod
TEST_ENV=scale

# Default provider account
# Allowed values: booking, order, ip
TEST_ACCOUNT=booking


# Provider login URLs
SCALE_PROVIDER_URL=https://scale.jaldee.com/business/login
PROD_PROVIDER_URL=https://jaldee.com/business/login


# Consumer URLs
SCALE_CONSUMER_URL=https://scale.jaldee.com/visionhospital/
PROD_CONSUMER_URL=https://www.jaldee.com/royalclinic/


# Scale provider accounts
SCALE_BOOKING_LOGIN_ID=your_scale_booking_login_id
SCALE_BOOKING_PASSWORD=your_scale_booking_password

SCALE_ORDER_LOGIN_ID=your_scale_order_login_id
SCALE_ORDER_PASSWORD=your_scale_order_password

SCALE_IP_LOGIN_ID=your_scale_ip_login_id
SCALE_IP_PASSWORD=your_scale_ip_password


# Production provider accounts
PROD_BOOKING_LOGIN_ID=your_prod_booking_login_id
PROD_BOOKING_PASSWORD=your_prod_booking_password

# Optional: add real values only if production order/IP tests are needed
PROD_ORDER_LOGIN_ID=your_prod_order_login_id
PROD_ORDER_PASSWORD=your_prod_order_password

PROD_IP_LOGIN_ID=your_prod_ip_login_id
PROD_IP_PASSWORD=your_prod_ip_password


# Consumer test numbers
SCALE_CONSUMER_PHONE=your_scale_consumer_phone
PROD_CONSUMER_PHONE=your_prod_consumer_phone


# Common settings
DEFAULT_TIMEOUT_MS=15000

REPORT_OUTPUT_DIR=reports/current
REPORT_ARTIFACT_DIR=reports/artifacts